{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "convex": "doppler run -- npx convex dev",
    "doppler:run": "doppler run -- npx convex dev",
    "doppler:pull": "doppler secrets download --no-file --format env-no-quotes > .env.local",
    "doppler:debug": "doppler run -- node --inspect node_modules/.bin/convex dev"
  },
  "dependencies": {
    "@workspace/models": "workspace:*",
    "convex": "^1.24.0",
    "convex-helpers": "^0.1.115"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./index.ts"
  }
}
