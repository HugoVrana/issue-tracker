{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "issue-tracker",
  "title": "Issue Tracker",
  "description": "Manage issues from Raycast",
  "icon": "icon.png",
  "author": "hugvrana",
  "license": "MIT",
  "commands": [
    {
      "name": "list-issues",
      "title": "List Issues",
      "description": "View and manage issues",
      "mode": "view"
    },
    {
      "name": "create-issue",
      "title": "Create Issue",
      "description": "Create a new issue",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.0.0",
    "@raycast/utils": "^1.0.0",
    "ws": "^8.0.0",
    "@workspace/db": "workspace:*",
    "@workspace/models": "workspace:*",
    "convex": "^1.36.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "remixicon": "^4.9.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "doppler:pull": "doppler secrets download --config dev_personal --no-file --format env-no-quotes > ~/.config/raycast/extensions/issue-tracker/.env",
    "build": "ray build",
    "dev": "pnpm doppler:pull && ray develop",
    "prod": "ray build",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
